{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codebase-gardener.dev/schemas/analysis_snapshot.schema.json",
  "type": "object",
  "required": ["schema_version", "analysis_snapshot_id", "repository_id", "commit_sha", "created_at", "logical_systems", "signals", "constitution_id"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "analysis_snapshot_id": { "type": "string" },
    "repository_id": { "type": "string" },
    "commit_sha": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" },
    "logical_systems": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["logical_system_id", "name", "paths"],
        "properties": {
          "logical_system_id": { "type": "string" },
          "name": { "type": "string" },
          "paths": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    },
    "signals": {
      "type": "object",
      "required": ["dependency_cycles", "hotspots", "dead_code_candidates", "ownership_risks", "test_gaps", "dependency_risks", "ci_failures"],
      "properties": {
        "dependency_cycles": { "type": "array", "items": { "type": "object" } },
        "hotspots": { "type": "array", "items": { "type": "object" } },
        "dead_code_candidates": { "type": "array", "items": { "type": "object" } },
        "ownership_risks": { "type": "array", "items": { "type": "object" } },
        "test_gaps": { "type": "array", "items": { "type": "object" } },
        "dependency_risks": { "type": "array", "items": { "type": "object" } },
        "ci_failures": { "type": "array", "items": { "type": "object" } }
      },
      "additionalProperties": false
    },
    "constitution_id": { "type": "string" }
  },
  "additionalProperties": false
}
