{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codebase-gardener.dev/schemas/gardening_session_result.schema.json",
  "type": "object",
  "required": ["schema_version", "gardening_session_id", "repository_id", "trigger", "status", "started_at", "finished_at", "phase_results", "opportunities_selected", "opportunities_deferred", "maintenance_pr_plans", "errors"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "gardening_session_id": { "type": "string" },
    "repository_id": { "type": "string" },
    "trigger": {
      "type": "object",
      "required": ["type"]
    },
    "status": { "type": "string" },
    "baseline_analysis_id": { "type": ["string", "null"] },
    "baseline_commit_sha": { "type": ["string", "null"] },
    "current_analysis_id": { "type": ["string", "null"] },
    "current_commit_sha": { "type": ["string", "null"] },
    "post_pr_refresh_analysis_id": { "type": ["string", "null"] },
    "drift_report": {
      "oneOf": [
        { "$ref": "https://codebase-gardener.dev/schemas/analysis_drift_report.schema.json" },
        { "type": "null" }
      ]
    },
    "started_at": { "type": "string", "format": "date-time" },
    "finished_at": { "type": "string", "format": "date-time" },
    "phase_results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["phase", "status", "summary"],
        "properties": {
          "phase": { "type": "string" },
          "status": { "type": "string" },
          "summary": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "opportunities_selected": { "type": "array", "items": { "type": "string" } },
    "opportunities_deferred": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["maintenance_opportunity_id", "reason"],
        "properties": {
          "maintenance_opportunity_id": { "type": "string" },
          "reason": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "maintenance_pr_plans": { "type": "array", "items": { "type": "string" } },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["phase", "message"],
        "properties": {
          "phase": { "type": "string" },
          "message": { "type": "string" },
          "maintenance_pr_plan_id": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
